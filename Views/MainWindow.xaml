<Window
    x:Class="YtDlpWPF.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:YtDlpWPF.ViewModels"
    xmlns:conv="clr-namespace:YtDlpWPF.Converters"
    Title="yt-dlp Wrapper"
    Width="900" Height="680"
    MinWidth="700" MinHeight="500"
    Background="{StaticResource BgBrush}"
    WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:BoolToInverseVisibilityConverter x:Key="BoolToInvVis"/>
        <conv:BoolNegateConverter              x:Key="BoolNeg"/>
    </Window.Resources>

    <Grid Margin="24" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="▼" FontSize="22" Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="yt-dlp Wrapper" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── URL Input ─────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNeg}}"
                     Tag="  Paste a YouTube or any supported URL here…">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Paste a YouTube or any supported URL here…"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="8,6" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button Grid.Column="2" Content="Paste"
                    Style="{StaticResource DefaultButton}"
                    IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNeg}}"
                    Click="PasteButton_Click"/>
        </Grid>

        <!-- ── Output Folder ─────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Save to:"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>

            <TextBox Grid.Column="2"
                     x:Name="OutputFolderTextBox"
                     Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Type a folder path or click Browse…"
                     LostFocus="OutputFolderTextBox_LostFocus"/>

            <Button Grid.Column="4" Content="Browse…"
                    Style="{StaticResource DefaultButton}"
                    IsEnabled="{Binding IsDownloading, Converter={StaticResource BoolNeg}}"
                    Click="BrowseButton_Click"/>
        </Grid>

        <!-- ── Format + Buttons ──────────────────────────────────── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Format:"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton Content="Video (MP4)" GroupName="fmt" Margin="0,0,16,0"
                             IsChecked="{Binding AudioOnly, Converter={StaticResource BoolNeg}}"/>
                <RadioButton Content="Audio only (MP3)" GroupName="fmt"
                             IsChecked="{Binding AudioOnly}"/>
            </StackPanel>

            <Button Grid.Column="4"
                    Content="⬇  Download"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding DownloadCommand}"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToInvVis}}"/>

            <Button Grid.Column="6"
                    Content="✕  Cancel"
                    Style="{StaticResource DefaultButton}"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <!-- ── Progress ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="8" >
            <ProgressBar Value="{Binding Progress}" Maximum="100"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── History + Log ─────────────────────────────────────── -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- History -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Download History"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding History}" SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" FontSize="12"/>
                                <TextBlock Text="{Binding StatusLine}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Log -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Log Output"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" Padding="8">
                        <TextBlock Text="{Binding LogText}"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </ScrollViewer>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
